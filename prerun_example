#!/usr/bin/env python3
"""MILC prerun decorator example.

PYTHON_ARGCOMPLETE_OK
"""
from milc import cli


@cli.prerun
def plain_prerun():
    cli.echo('plain')


@cli.prerun('token', source='kwargs')
def configured_prerun(token, source=None):
    cli.echo(f'configured:{token}:{source}')


@cli.entrypoint('Entrypoint for prerun decorator tests.')
def main(cli):
    cli.echo('entrypoint')


@cli.subcommand('Subcommand for prerun decorator tests.')
def hello(cli):
    cli.echo('subcommand')


if __name__ == '__main__':
    cli()
